# 백엔드 미완성 구간을 mock으로 시연하려면 true (기본 false → 실제 /api 호출)
VITE_USE_MOCK=false

# 소셜 로그인 OAuth client_id (카카오/구글).
# 비어두면 해당 버튼은 기존 stub(빈 코드) 동작 — 키 없이도 데모 가능.
# 채우면 실제 인가 코드 플로우로 전환. redirect_uri는 {origin}/auth/callback/{provider}.
# provider 콘솔에 위 redirect_uri를 등록해야 함(예: http://localhost:5173/auth/callback/kakao).
VITE_KAKAO_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
